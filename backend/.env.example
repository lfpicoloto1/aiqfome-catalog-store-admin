MAGALU_CLIENT_ID=
MAGALU_CLIENT_SECRET=
# Host da plataforma (sem /api/v2)
AIQFOME_API_BASE_URL=https://plataforma.aiqfome.com
# Opcional: path da API V2 (omissão /api/v2 → GET …/api/v2/store)
# AIQFOME_API_V2_PREFIX=/api/v2
# Opcional: raiz completa da V2 (substitui base + prefixo)
# AIQFOME_API_V2_ROOT=https://plataforma.aiqfome.com/api/v2
# Se 403 só em Python e Postman OK: não definas (httpx ignora proxy do sistema).
# Só ativa se precisares mesmo de HTTP(S)_PROXY para a plataforma:
# AIQFOME_HTTP_TRUST_ENV=true
# User-Agent para a plataforma (omissão = Chrome-like; "none" = default httpx)
# AIQFOME_HTTP_USER_AGENT=PostmanRuntime/7.43.0
# Log curl equivalente para a plataforma (inclui Bearer). Produção: LOG_AIQFOME_HTTP_DEBUG=0
# LOG_AIQFOME_HTTP_DEBUG=1
# Comma-separated origins (Geraldo + your app URL + local dev)
CORS_ORIGINS=https://geraldo-restaurantes.aiqfome.com,http://localhost:5173
